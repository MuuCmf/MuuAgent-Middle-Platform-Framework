# ===========================================
# 生产环境配置文件模板
# 复制此文件为 .env.production 并修改配置
# ===========================================

# ===========================================
# 数据库配置（Docker 环境下会被 docker-compose.yml 覆盖）
# ===========================================
DATABASE_URL="mysql://muu_agent:MuAgent_2026_Prod_Pass@mysql:3306/muu_agent_platform?connection_limit=10&pool_timeout=30"

# ===========================================
# 服务配置
# ===========================================

# 服务端口（Docker 环境下固定为 3002，请勿修改）
PORT=3002

# Node 环境
NODE_ENV=production

# ===========================================
# 安全配置
# ===========================================

# JWT 密钥（生产环境必须修改！）
# 生成方法: openssl rand -base64 64
JWT_SECRET="CHANGE-ME-TO-A-STRONG-SECRET-KEY"

# JWT 过期时间
JWT_EXPIRES_IN=2h
REFRESH_TOKEN_EXPIRES_IN=7d

# ===========================================
# Redis 配置（Docker 环境下会被 docker-compose.yml 覆盖）
# ===========================================
REDIS_URL="redis://redis:6379"

# ===========================================
# 日志配置
# ===========================================
LOG_LEVEL="info"

# ===========================================
# 开发工具配置（生产环境建议关闭）
# ===========================================
ENABLE_SWAGGER=false
ENABLE_CORS=true
CORS_ORIGINS="https://your-domain.com"

# ===========================================
# 模块自动发现
# ===========================================
ENABLED_MODULES=all

# ===========================================
# 向量库配置（Docker 环境下会被 docker-compose.yml 覆盖）
# ===========================================
VECTOR_DB_TYPE=qdrant
VECTOR_DB_HOST=qdrant
VECTOR_DB_PORT=6333
VECTOR_DB_COLLECTION=knowledge_base
VECTOR_DB_DIMENSION=1536
VECTOR_DB_SSL=false

# ===========================================
# 文件上传配置
# ===========================================
FILE_UPLOAD_DIR=./uploads
FILE_MAX_SIZE=10485760
FILE_MAX_FILES=1000
FILE_DEFAULT_STORAGE=local
FILE_ALLOWED_TYPES=["image","video","audio","pdf","doc","excel","txt","md"]
FILE_DENIED_EXTENSIONS=[".exe",".bat",".sh",".cmd",".msi",".dll"]

# ===========================================
# OSS 配置（如需对象存储请填写）
# ===========================================
# OSS_REGION=oss-cn-hangzhou
# OSS_ACCESS_KEY_ID=your-access-key-id
# OSS_ACCESS_KEY_SECRET=your-access-key-secret
# OSS_BUCKET=your-bucket
# OSS_CDN_URL=https://cdn.example.com

# ===========================================
# Docker Compose 变量
# ===========================================

# MySQL 密码
MYSQL_ROOT_PASSWORD=Root_Pass_2026
MYSQL_PASSWORD=MuAgent_2026_Prod_Pass

# 端口映射
APP_PORT=3002
MYSQL_PORT=3306
REDIS_PORT=6379
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# 前端构建变量
VITE_API_BASE_URL=
VITE_WS_URL=

# 资源限制
APP_MEMORY_LIMIT=2G
APP_MEMORY_RESERVATION=512M
