# ===========================================
# 开发环境配置文件示例
# 使用方法: 复制此文件为 .env 并修改配置
# ===========================================

# ===========================================
# 数据库配置
# ===========================================

# 数据库（开发环境推荐）
DATABASE_URL="mysql://root:123456@localhost:3306/muu_agent_platform"

# MySQL 数据库
# DATABASE_URL="mysql://root:password@localhost:3306/muu_ai_platform?connection_limit=10&pool_timeout=30"

# ===========================================
# 服务配置
# ===========================================

# 服务端口
PORT=9898

# Node 环境: development, production, test
NODE_ENV=development

# ===========================================
# 安全配置
# ===========================================

# JWT 密钥（用于 Token 签名）
# 生成方法: openssl rand -base64 64
JWT_SECRET="your-jwt-secret-key-change-in-production"

# JWT 过期时间（默认 2 小时）
JWT_EXPIRES_IN=2h
REFRESH_TOKEN_EXPIRES_IN=7d

# ===========================================
# Redis 配置（可选）
# ===========================================

# Redis 连接地址（用于限流和缓存）
# 如果不使用 Redis，限流将使用内存存储
REDIS_URL="redis://localhost:6379"

# Redis 密码（如果有）
# REDIS_PASSWORD=""

# ===========================================
# 日志配置
# ===========================================

# 日志级别: error, warn, info, debug, verbose
LOG_LEVEL="info"

# ===========================================
# 健康检查
# ===========================================

# 健康检查间隔（毫秒）
HEALTH_CHECK_INTERVAL=30000

# ===========================================
# 开发工具配置
# ===========================================

# 是否启用 Swagger API 文档
ENABLE_SWAGGER=true

# Swagger 文档路径
SWAGGER_PATH="api-docs"

# 是否启用 CORS
ENABLE_CORS=true

# CORS 允许的源（逗号分隔）
CORS_ORIGINS="http://localhost:3000,http://localhost:8080"

# ===========================================
# 数据库连接池配置（MySQL）
# ===========================================

# 连接池大小
DB_CONNECTION_LIMIT=10

# 连接池超时时间（秒）
DB_POOL_TIMEOUT=30

# ===========================================
# 调试配置
# ===========================================

# 是否启用调试模式
DEBUG=false

# 调试端口
DEBUG_PORT=9229

# ===========================================
# 模块自动发现
# ===========================================

# 启用哪些业务模块（逗号分隔）
# - 不设置或 "all"：加载全部模块（默认）
# - "all,-模块1,-模块2"：排除指定模块
# - "模块1,模块2"：仅加载指定模块 + 传递依赖自动补全
#
# 示例：
#   ENABLED_MODULES=all
#   ENABLED_MODULES=agent,skill,kb,model
#   ENABLED_MODULES=all,-log,-oauth
ENABLED_MODULES=all

# ===========================================
# 向量库配置（Qdrant）
# ===========================================

# 向量库类型
VECTOR_DB_TYPE=qdrant

# Qdrant 连接配置
VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=6333

# Qdrant API Key（如需要认证）
# VECTOR_DB_API_KEY=your-api-key

# 默认集合名称
VECTOR_DB_COLLECTION=knowledge_base

# 向量维度（OpenAI text-embedding-3-small 默认 1536）
VECTOR_DB_DIMENSION=1536

# 是否启用 SSL
VECTOR_DB_SSL=false

# 文件上传配置
FILE_UPLOAD_DIR=./uploads
FILE_MAX_SIZE=10485760
FILE_MAX_FILES=1000
FILE_DEFAULT_STORAGE=local

# 允许的文件类型
FILE_ALLOWED_TYPES=["image","video","audio","pdf","doc","excel","txt"]

# 禁止的扩展名
FILE_DENIED_EXTENSIONS=[".exe",".bat",".sh",".cmd",".msi",".dll"]

# OSS 配置
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET=your-bucket
OSS_CDN_URL=https://cdn.example.com

# S3 配置
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET=your-bucket
S3_CDN_URL=https://cdn.example.com/s3

