generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// AI模型表 - 存储所有AI模型配置
model Model {
  id          String   @id @default(uuid())
  name        String   /// 模型名称
  code        String   @unique /// 模型唯一标识码
  type        String   /// 模型类型: llm / embedding / tts / asr / image / multimodal
  provider    String   /// 提供商: openai / ollama / azure / aliyun / tencent / custom
  endpoint    String   /// 模型API地址
  apiKey      String?  /// API密钥
  weight      Int      @default(1) /// 权重(用于负载均衡)
  maxTokens   Int      @default(4096) /// 最大Token数
  temperature Float    @default(0.7) /// 温度参数
  status      Boolean  @default(true) /// 是否启用
  description String?  /// 模型描述
  config      String?  /// 额外配置(JSON格式)
  tags        String?  /// 模型标签(JSON数组): chat, reasoning, drawing, embedding, voice
  category    String?  /// 模型分类: general, code, math, creative, professional
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// 关联MCP规则
  mcpRules    McpRule[]
  /// 关联调用日志
  invokeLogs  AiInvokeLog[]
  /// 关联健康记录
  healthRecords ModelHealth[]

  @@index([type, status])
  @@index([provider])
  @@index([category])
  @@map("models")
}

/// 模型参数模板表 - 预设模型调用参数
model ModelTemplate {
  id             String   @id @default(uuid())
  name           String   /// 模板名称
  code           String   @unique /// 模板唯一标识
  modelType      String   /// 适配模型类型: llm / embedding / multimodal
  temperature    Float    @default(0.7) /// 温度参数(0-1)
  topP           Float    @default(0.7) /// 核采样参数(0-1)
  contextWindow  Int      @default(8192) /// 上下文窗口大小
  maxTokens      Int      @default(1000) /// 最大生成长度
  sceneTag       String?  /// 场景标签: customer_service / creative / vector / multimodal / code
  description    String?  /// 模板描述
  remark         String?  /// 备注
  isDefault      Boolean  @default(false) /// 是否为默认模板
  status         Boolean  @default(true) /// 是否启用
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([modelType, status])
  @@index([sceneTag])
  @@index([isDefault])
  @@map("model_templates")
}

/// MCP调度策略表 - 模型控制平面配置
model McpStrategy {
  id            String  @id @default(uuid())
  modelType     String  @unique /// 模型类型
  strategy      String  @default("weight") /// 调度策略: weight / random / round_robin / failover
  retryCount    Int     @default(3) /// 重试次数
  timeout       Int     @default(30000) /// 超时时间(毫秒)
  fallbackModelId String? /// 降级模型ID
  enableCircuit Boolean @default(true) /// 是否启用熔断
  circuitThreshold Int @default(5) /// 熔断错误阈值
  circuitTimeout   Int @default(300000) /// 熔断恢复时间(毫秒)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("mcp_strategies")
}

/// MCP限流熔断规则表 - 单模型级别的限流配置
model McpRule {
  id              String  @id @default(uuid())
  modelId         String  /// 关联模型ID
  qpsLimit        Int     @default(10) /// QPS限制
  maxConcurrent   Int     @default(5) /// 最大并发数
  currentConcurrent Int   @default(0) /// 当前并发数
  circuitStatus   String  @default("closed") /// 熔断状态: closed / open / half_open
  errorCount      Int     @default(0) /// 错误计数
  lastErrorTime   DateTime? /// 最后错误时间
  circuitOpenTime DateTime? /// 熔断开启时间
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  model Model @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("mcp_rules")
}

/// 技能表 - 可被Agent调用的工具
model Skill {
  id          String   @id @default(uuid())
  name        String   /// 技能名称
  code        String   /// 技能唯一标识
  description String   @db.Text /// 功能描述(给LLM看)
  type        String   /// 类型: http / function / database / rpc / mcp
  params      String   @db.Text /// 入参描述(JSON格式)
  config      String   @db.Text /// 执行配置(JSON格式)
  status      Boolean  @default(true) /// 是否启用
  timeout     Int      @default(30000) /// 超时时间(毫秒)

  // ===== 函数技能专用字段 =====
  codeType      String?  @map("code_type") /// 代码类型: builtin / plugin / sandbox
  pluginName    String?  @map("plugin_name") /// 插件名称(plugin类型专用)
  functionName  String?  @map("function_name") /// 函数名称
  codeContent   String?  @map("code_content") @db.Text /// 沙箱代码内容(sandbox类型专用)

  // ===== 应用隔离 =====
  appCode       String?  @map("app_code") /// 所属应用标识
  isPublic      Boolean  @default(false) @map("is_public") /// 是否公开（公开=所有应用可用）

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  /// 关联
  app           AppTenant? @relation(fields: [appCode], references: [code])
  invokeLogs    SkillInvokeLog[]

  @@unique([code, appCode]) /// 同一应用下code唯一
  @@index([type, status])
  @@index([codeType])
  @@index([appCode])
  @@index([isPublic])
  @@map("skills")
}

/// 智能体表 - AI Agent配置
model Agent {
  id              String   @id @default(uuid())
  name            String   /// 智能体名称
  code            String   /// 智能体唯一标识
  description     String?  /// 智能体描述
  systemPrompt    String   @db.Text /// 系统提示词
  promptTemplateCode String? @map("prompt_template_code") /// 使用的提示词模板标识
  skills          String   @db.Text /// 绑定的技能code列表(JSON数组)
  mcpServers      String?  @db.Text /// 绑定的MCP Server配置(JSON数组)
  knowledgeBases  String?  @db.Text /// 绑定的知识库code列表(JSON数组)
  maxSteps        Int      @default(5) /// 最大执行步数
  temperature     Float    @default(0.7) /// 温度参数
  status          Boolean  @default(true) /// 是否启用

  // ===== 推理模式配置 =====
  reasoningMode     String  @default("NONE") @map("reasoning_mode") /// 推理模式: NONE/REACT/PLAN/REFLECT
  reasoningPrompt   String? @map("reasoning_prompt") @db.Text /// 自定义推理提示词

  // ===== 知识库检索配置 =====
  kbRetrievalMode   String  @default("tool") @map("kb_retrieval_mode") /// 知识库检索模式: tool

  // ===== 应用隔离 =====
  appCode         String?  @map("app_code") /// 所属应用标识
  isPublic        Boolean  @default(false) @map("is_public") /// 是否公开（公开=所有应用可用）

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  /// 关联
  app             AppTenant? @relation(fields: [appCode], references: [code])
  invokeLogs      AgentInvokeLog[]

  @@unique([code, appCode]) /// 同一应用下code唯一
  @@index([status])
  @@index([appCode])
  @@index([isPublic])
  @@index([promptTemplateCode])
  @@map("agents")
}

/// AI调用日志表 - 记录所有AI模型调用
model AiInvokeLog {
  id          String   @id @default(uuid())
  modelId     String?  @map("model_id") /// 调用的模型ID
  modelCode   String   @map("model_code") /// 模型标识码
  modelType   String   @map("model_type") /// 模型类型
  request     String   @db.Text /// 请求数据(JSON)
  response    String?  @db.Text /// 响应数据(JSON)
  costMs      Int      @map("cost_ms") /// 耗时(毫秒)
  inputTokens Int?     @map("input_tokens") /// 输入Token数
  outputTokens Int?    @map("output_tokens") /// 输出Token数
  success     Boolean  /// 是否成功
  errorMessage String? @map("error_message") @db.Text /// 错误信息
  clientIp    String?  @map("client_ip") /// 客户端IP
  userAgent   String?  @map("user_agent") /// 用户代理
  uid         String?  /// 调用用户唯一标识(透传)

  // ===== 应用隔离 =====
  appCode     String?  @map("app_code") /// 应用标识

  createdAt   DateTime @default(now())

  model       Model? @relation(fields: [modelId], references: [id])
  app         AppTenant? @relation(fields: [appCode], references: [code])

  @@index([modelId, createdAt])
  @@index([modelType, createdAt])
  @@index([success, createdAt])
  @@index([uid, createdAt])
  @@index([appCode, createdAt])
  @@map("ai_invoke_logs")
}

/// 技能调用日志表 - 记录技能调用情况
model SkillInvokeLog {
  id           String   @id @default(uuid())
  skillId      String   @map("skill_id") /// 技能ID
  skillCode    String   @map("skill_code") /// 技能标识
  agentLogId   String?  @map("agent_invoke_log_id") /// 关联Agent调用日志ID
  params       String?  @db.Text /// 调用参数(JSON)
  result       String?  @db.Text /// 返回结果(JSON)
  success      Boolean  /// 是否成功
  errorMessage String?  @map("error_message") @db.Text /// 错误信息
  costMs       Int      @map("cost_ms") /// 耗时(毫秒)
  clientIp     String?  @map("client_ip") /// 客户端IP
  uid          String?  /// 调用用户唯一标识(透传)

  // ===== 应用隔离 =====
  appCode      String?  @map("app_code") /// 应用标识

  createdAt    DateTime @default(now())

  skill        Skill @relation(fields: [skillId], references: [id])
  app          AppTenant? @relation(fields: [appCode], references: [code])

  @@index([skillId, createdAt])
  @@index([skillCode, createdAt])
  @@index([uid, createdAt])
  @@index([appCode, createdAt])
  @@map("skill_invoke_logs")
}

/// 智能体调用日志表 - 记录Agent对话
model AgentInvokeLog {
  id           String   @id @default(uuid())
  agentId      String   @map("agent_id") /// 智能体ID
  conversationId String? @map("conversation_id") /// 会话ID
  userMessage  String   @map("user_message") @db.Text /// 用户消息
  agentResponse String? @map("agent_response") @db.Text /// 智能体回复
  steps        String?  @db.Text /// 执行步骤(JSON)
  totalCostMs  Int      @map("total_cost_ms") /// 总耗时(毫秒)
  success      Boolean  /// 是否成功
  errorMessage String?  @map("error_message") @db.Text /// 错误信息
  clientIp     String?  @map("client_ip") /// 客户端IP
  uid          String?  /// 调用用户唯一标识(透传)

  // ===== 推理模式 =====
  reasoningMode String? @map("reasoning_mode") /// 推理模式: NONE/REACT/PLAN/REFLECT

  // ===== 应用隔离 =====
  appCode      String?  @map("app_code") /// 应用标识

  createdAt    DateTime @default(now())

  agent        Agent @relation(fields: [agentId], references: [id])
  app          AppTenant? @relation(fields: [appCode], references: [code])

  /// 关联推理步骤
  reasoningSteps ReasoningStep[]

  @@index([agentId, createdAt])
  @@index([conversationId])
  @@index([uid, createdAt])
  @@index([appCode, createdAt])
  @@map("agent_invoke_logs")
}

/// 模型健康检查记录表
model ModelHealth {
  id           String   @id @default(uuid())
  modelId      String   /// 模型ID
  status       String   /// 健康状态: healthy / unhealthy / unknown
  responseTime Int?     /// 响应时间(毫秒)
  errorMessage String?  /// 错误信息
  checkedAt    DateTime @default(now())

  model Model @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId, checkedAt])
  @@map("model_health_records")
}

/// 应用/租户表 - 多租户支持
model AppTenant {
  id          String   @id @default(uuid())
  name        String   /// 应用名称
  code        String   @unique /// 应用标识
  apiKey      String   @unique /// API密钥
  secretKey   String   /// 密钥

  // ===== 配额限制 =====
  qpsLimit      Int      @default(100) @map("qps_limit") /// QPS限制
  dailyLimit    Int      @default(10000) @map("daily_limit") /// 每日调用限制
  tokenLimit    Int      @default(1000000) @map("token_limit") /// Token配额（月）

  // ===== OAuth 配置 =====
  enableOAuth   Boolean  @default(false) @map("enable_oauth") /// 是否启用OAuth

  // ===== 状态 =====
  status        Boolean  @default(true)
  expireAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // ===== 关联 =====
  agents        Agent[]
  skills        Skill[]
  kbInfos       KbInfo[]
  conversations Conversation[]
  promptTemplates PromptTemplate[]
  oauthClients  OAuthClient[]
  aiInvokeLogs  AiInvokeLog[]
  agentInvokeLogs AgentInvokeLog[]
  skillInvokeLogs SkillInvokeLog[]
  kbRetrievalLogs KbRetrievalLog[]
  appUsages     AppUsage[]

  @@index([code])
  @@index([apiKey])
  @@index([status])
  @@map("app_tenants")
}

/// 应用每日使用量统计表
model AppUsage {
  id          String   @id @default(uuid())
  appCode     String   @map("app_code") /// 应用标识
  date        DateTime /// 日期
  callCount   Int      @default(0) @map("call_count") /// 调用次数
  tokenCount  Int      @default(0) @map("token_count") /// Token使用量
  inputTokens Int      @default(0) @map("input_tokens") /// 输入Token
  outputTokens Int     @default(0) @map("output_tokens") /// 输出Token

  app         AppTenant @relation(fields: [appCode], references: [code])

  @@unique([appCode, date])
  @@index([appCode])
  @@index([date])
  @@map("app_usage")
}

/// 限流规则表 - 支持多级别限流配置
model RateLimitRule {
  id              String   @id @default(uuid())
  level           String   /// 限流级别: global / app / interface / model
  target          String   /// 限流目标: global标识全局、appCode、interface路径、modelId
  qpsLimit        Int      @default(100) /// QPS限制(每秒请求数)
  concurrentLimit Int      @default(10) /// 并发限制(同时请求数)
  dailyLimit      Int      @default(10000) /// 每日调用限制
  burstSize       Int      @default(20) /// 突发流量大小(令牌桶容量)
  enableQueue     Boolean  @default(false) /// 是否启用队列
  queueSize       Int      @default(100) /// 队列大小
  queueTimeout    Int      @default(5000) /// 队列超时时间(毫秒)
  status          Boolean  @default(true) /// 是否启用
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  /// 关联限流计数器
  rateLimitCounters RateLimitCounter[]

  @@unique([level, target])
  @@index([level, status])
  @@map("rate_limit_rules")
}

/// 限流计数器表 - 实时统计限流数据
model RateLimitCounter {
  id                String   @id @default(uuid())
  ruleId            String   /// 关联限流规则ID
  currentQps        Int      @default(0) /// 当前QPS
  currentConcurrent Int      @default(0) /// 当前并发数
  todayCount        Int      @default(0) /// 今日调用次数
  lastSecond        Int      @default(0) /// 上一秒时间戳
  lastResetDate     String   @default("") /// 上次重置日期
  tokens            Float    @default(100) /// 令牌桶当前令牌数
  lastTokenUpdate   DateTime @default(now()) /// 上次令牌更新时间
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  /// 关联限流规则
  rateLimitRule RateLimitRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@map("rate_limit_counters")
}

/// 限流黑名单表 - 记录被限流的请求
model RateLimitBlacklist {
  id          String   @id @default(uuid())
  clientIp    String   /// 客户端IP
  appId       String?  /// 应用ID
  reason      String   /// 限流原因
  blockUntil  DateTime /// 封禁截止时间
  createdAt   DateTime @default(now())

  @@index([clientIp, blockUntil])
  @@index([appId, blockUntil])
  @@map("rate_limit_blacklists")
}

/// 管理员表 - 中台管理后台用户
model AdminUser {
  id           String   @id @default(uuid())
  username     String   @unique /// 登录账号
  password     String   /// 加密密码(BCrypt)
  nickname     String?  /// 昵称
  email        String?  /// 邮箱
  phone        String?  /// 手机号
  role         String   @default("admin") /// 角色: admin / ops / read
  isSuperAdmin Boolean  @default(false) @map("is_super_admin") /// 是否为超级管理员
  status       Int      @default(1) /// 状态: 1正常 0禁用
  lastLoginAt  DateTime? /// 最后登录时间
  lastLoginIp  String?  /// 最后登录IP
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([username])
  @@index([status])
  @@index([isSuperAdmin])
  @@map("admin_users")
}

/// 知识库表 - 应用级隔离
model KbInfo {
  id              String   @id @default(uuid())
  kbName          String   /// 知识库名称
  kbCode          String   /// 知识库唯一标识

  // ===== 配置参数 =====
  embeddingModel  String   @default("doubao-embedding-v1") @map("embedding_model") /// 向量模型
  chunkSize       Int      @default(500) @map("chunk_size") /// 切片大小
  chunkOverlap    Int      @default(100) @map("chunk_overlap") /// 切片重叠
  similarityThresh Float   @default(0.7) @map("similarity_thresh") /// 相似度阈值
  topN            Int      @default(5) /// 召回条数
  retrievalMethod String   @default("vector") @map("retrieval_method") /// 检索方式: vector=向量检索, bm25=BM25检索

  // ===== 权限与状态 =====
  isPublic        Boolean  @default(false) @map("is_public") /// 是否公开（公开=所有应用可检索）
  status          Boolean  @default(true) /// 状态：true=启用，false=禁用
  description     String?  @db.Text /// 描述

  // ===== 应用隔离 =====
  appCode         String?  @map("app_code") /// 所属应用标识

  // ===== 创建者信息 =====
  createdBy       String?  /// 创建者uid
  updatedBy       String?  /// 更新者uid

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  isDeleted       Boolean  @default(false) @map("is_deleted") /// 软删除

  /// 关联
  app             AppTenant? @relation(fields: [appCode], references: [code])
  documents       KbDocument[]
  chunks          KbChunk[]
  retrievalLogs   KbRetrievalLog[]

  @@unique([kbCode, appCode]) /// 同一应用下kbCode唯一
  @@index([kbCode])
  @@index([appCode])
  @@index([isPublic, status])
  @@index([createdBy])
  @@map("kb_infos")
}

/// 文档表 - 知识库下的文档
model KbDocument {
  id              String   @id @default(uuid())
  kbId            String   @map("kb_id") /// 所属知识库ID
  docName         String   @map("doc_name") /// 文档名称
  docCode         String?  @map("doc_code") /// 文档唯一标识
  fileType        String   @map("file_type") /// 文档类型: pdf/word/txt/md
  fileUrl         String   @map("file_url") /// 文档存储路径
  fileSizeKb      Int      @map("file_size_kb") /// 文档大小

  // ===== 状态管理 =====
  status          Int      @default(0) /// 状态: 0=解析中,1=正常,2=失败,3=禁用
  totalChunks     Int      @default(0) @map("total_chunks") /// 切片总数

  // ===== 创建者信息 =====
  createdBy       String?  @map("created_by") /// 创建者uid
  updatedBy       String?  @map("updated_by") /// 更新者uid

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  isDeleted       Boolean  @default(false) @map("is_deleted")

  kbInfo          KbInfo   @relation(fields: [kbId], references: [id], onDelete: Cascade)
  chunks          KbChunk[]

  @@index([kbId, status])
  @@index([createdBy])
  @@map("kb_documents")
}

/// 切片表 - 文档切片元数据
model KbChunk {
  id              String   @id @default(uuid())
  kbId            String   @map("kb_id") /// 所属知识库ID
  docId           String   @map("doc_id") /// 所属文档ID
  content         String   @db.Text /// 切片文本内容
  chunkIndex      Int      @map("chunk_index") /// 切片序号
  vectorId        String?  @map("vector_id") /// 向量库ID
  status          Int      @default(0) /// 状态: 0=未向量化,1=已向量化,2=失败

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  isDeleted       Boolean  @default(false) @map("is_deleted")

  kbInfo          KbInfo   @relation(fields: [kbId], references: [id], onDelete: Cascade)
  document        KbDocument @relation(fields: [docId], references: [id], onDelete: Cascade)

  @@index([kbId, docId])
  @@index([kbId, status])
  @@index([vectorId])
  @@map("kb_chunks")
}

/// 检索日志表 - 记录检索历史
model KbRetrievalLog {
  id              String   @id @default(uuid())
  kbId            String   @map("kb_id") /// 知识库ID
  uid             String?  /// 调用者uid（仅用于日志记录）
  query           String   @db.Text /// 查询问题
  topN            Int      /// 召回条数
  similarityThresh Float   @map("similarity_thresh") /// 相似度阈值
  retrievalCount  Int      @default(0) @map("retrieval_count") /// 召回切片数量
  results         String?  @db.Text /// 检索结果(JSON数组): [{"chunkId":"xxx","score":0.85,"docName":"文档名","content":"切片内容摘要"}]
  costTime        Int      @map("cost_time") /// 检索耗时
  requestId       String   @map("request_id") /// 链路ID
  clientIp        String?  @map("client_ip") /// 客户端IP

  // ===== 应用隔离 =====
  appCode         String?  @map("app_code") /// 应用标识

  createdAt       DateTime @default(now())

  kbInfo          KbInfo   @relation(fields: [kbId], references: [id], onDelete: Cascade)
  app             AppTenant? @relation(fields: [appCode], references: [code])

  @@index([kbId, createdAt])
  @@index([uid, createdAt])
  @@index([requestId])
  @@index([appCode, createdAt])
  @@map("kb_retrieval_logs")
}

/// OAuth客户端
model OAuthClient {
  id                String   @id @default(uuid())
  clientId          String   @unique @default(uuid()) @map("client_id") /// 客户端ID
  clientSecret      String   @map("client_secret") /// 客户端密钥
  name              String   /// 客户端名称
  redirectUris      String   @map("redirect_uris") @db.Text /// 回调地址列表(JSON数组)
  scopes            String   @map("scopes") @db.Text /// 权限范围(JSON数组)
  grants            String   @default("[\"authorization_code\",\"refresh_token\"]") /// 授权类型(JSON数组)
  status            Int      @default(1) /// 状态: 1正常 0禁用

  // ===== 应用隔离 =====
  appCode           String?  @map("app_code") /// 绑定的应用标识

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  /// 关联
  app               AppTenant? @relation(fields: [appCode], references: [code])
  tokens            OAuthToken[]
  codes             OAuthCode[]

  @@index([clientId])
  @@index([appCode])
  @@map("oauth_clients")
}

/// 授权码
model OAuthCode {
  id                String   @id @default(uuid())
  code              String   @unique /// 授权码
  clientId          String   @map("client_id") /// 客户端ID
  userId            String   @map("user_id") /// 用户ID
  redirectUri       String   @map("redirect_uri") /// 回调地址
  scope             String   @db.Text /// 权限范围
  state             String?  /// 状态参数
  expiresAt         DateTime @map("expires_at") /// 过期时间
  createdAt         DateTime @default(now())

  client            OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)

  @@index([code])
  @@index([expiresAt])
  @@map("oauth_codes")
}

/// 访问令牌
model OAuthToken {
  id                String    @id @default(uuid())
  accessToken       String    @unique @map("access_token") /// 访问令牌
  refreshToken      String?   @unique @map("refresh_token") /// 刷新令牌
  clientId          String    @map("client_id") /// 客户端ID
  userId            String    @map("user_id") /// 用户ID
  scope             String    @db.Text /// 权限范围
  expiresAt         DateTime  @map("expires_at") /// 访问令牌过期时间
  refreshExpiresAt  DateTime? @map("refresh_expires_at") /// 刷新令牌过期时间
  createdAt         DateTime  @default(now())

  client            OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)

  @@index([accessToken])
  @@index([refreshToken])
  @@index([expiresAt])
  @@map("oauth_tokens")
}

/// 推理步骤记录表 - 记录ReAct推理过程
model ReasoningStep {
  id          String   @id @default(uuid())
  agentLogId  String   @map("agent_invoke_log_id") /// 关联调用日志ID
  stepNumber  Int      @map("step_number") /// 步骤序号
  thought     String?  @db.Text /// 思考内容
  action      String?  /// 执行的动作
  actionInput String?  @map("action_input") @db.Text /// 动作输入参数
  observation String?  @db.Text /// 观察结果
  status      String   @default("pending") /// 状态: pending/success/failed
  costMs      Int?     @map("cost_ms") /// 耗时(毫秒)
  createdAt   DateTime @default(now())

  agentLog    AgentInvokeLog @relation(fields: [agentLogId], references: [id], onDelete: Cascade)

  @@index([agentLogId])
  @@map("reasoning_steps")
}

/// 会话表 - 管理对话会话（支持多种对话类型）
model Conversation {
  id               String   @id @default(uuid())
  conversationType String   @default("agent") @map("conversation_type") /// 会话类型: agent/model/kb-rag
  targetId         String   @map("target_id") /// 目标ID（智能体ID/模型标识/知识库ID）
  title            String?  /// 会话标题（自动生成或用户设置）
  uid              String?  /// 用户唯一标识（用于用户隔离）
  status           String   @default("active") /// 状态: active/archived/deleted
  lastMessageAt    DateTime @default(now()) @map("last_message_at") /// 最后消息时间
  messageCount     Int      @default(0) @map("message_count") /// 消息数量

  // ===== 应用隔离 =====
  appCode          String?  @map("app_code") /// 所属应用标识

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  /// 关联
  app              AppTenant? @relation(fields: [appCode], references: [code])
  messages         Message[]

  @@index([conversationType, targetId, createdAt])
  @@index([uid, createdAt])
  @@index([appCode])
  @@index([status])
  @@map("conversations")
}

/// 消息表 - 存储对话消息
model Message {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id") /// 会话ID
  role           String   /// 角色: user/assistant/system/tool
  content        String   @db.Text /// 消息内容
  toolCalls      String?  @map("tool_calls") @db.Text /// 工具调用信息(JSON)
  toolCallId     String?  @map("tool_call_id") /// 工具调用ID
  tokenCount     Int?     @map("token_count") /// Token数量
  reasoningSteps String?  @map("reasoning_steps") @db.Text /// 推理步骤(JSON)
  metadata       String?  @db.Text /// 额外元数据(JSON)，如检索结果、模型参数等
  createdAt      DateTime @default(now())

  /// 关联
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

/// Prompt模板表 - 存储提示词模板
model PromptTemplate {
  id          String   @id @default(uuid())
  code        String   /// 模板唯一标识
  name        String   /// 模板名称
  category    String   /// 分类: agent/rag/react/skill/custom
  content     String   @db.Text /// Prompt内容（支持变量占位符）
  variables   String?  @db.Text /// 变量定义（JSON格式）
  version     Int      @default(1) /// 当前版本号
  isDefault   Boolean  @default(false) @map("is_default") /// 是否默认模板
  status      Boolean  @default(true) /// 是否启用
  description String?  @db.Text /// 模板描述
  tags        String?  /// 标签（JSON数组）
  metadata    String?  @db.Text /// 元数据（JSON格式）
  createdBy   String?  @map("created_by") /// 创建者

  // ===== 应用隔离 =====
  appCode     String?  @map("app_code") /// 所属应用标识
  isPublic    Boolean  @default(false) @map("is_public") /// 是否公开

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// 关联
  app         AppTenant? @relation(fields: [appCode], references: [code])
  versions    PromptVersion[]
  invokeLogs  PromptInvokeLog[]

  @@unique([code, appCode]) /// 同一应用下code唯一
  @@index([category, status])
  @@index([appCode])
  @@index([isPublic])
  @@index([isDefault])
  @@index([createdAt])
  @@map("prompt_templates")
}

/// Prompt版本历史表 - 记录模板版本变更
model PromptVersion {
  id          String   @id @default(uuid())
  templateId  String   @map("template_id") /// 关联模板ID
  version     Int      /// 版本号
  content     String   @db.Text /// Prompt内容
  variables   String?  @db.Text /// 变量定义
  changeLog   String?  @map("change_log") @db.Text /// 变更说明
  changeType  String   @default("update") @map("change_type") /// 变更类型: create/update/rollback
  createdBy   String?  @map("created_by") /// 创建者
  createdAt   DateTime @default(now())

  template PromptTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, version])
  @@index([templateId])
  @@index([createdAt])
  @@map("prompt_versions")
}

/// Prompt调用日志表 - 记录模板调用情况
model PromptInvokeLog {
  id            String   @id @default(uuid())
  templateId    String?  @map("template_id") /// 关联模板ID
  templateCode  String   @map("template_code") /// 模板标识
  templateVersion Int    @map("template_version") /// 模板版本
  variables     String?  @db.Text /// 渲染变量（JSON格式）
  renderedPrompt String  @map("rendered_prompt") @db.Text /// 渲染后的Prompt
  modelId       String?  @map("model_id") /// 调用的模型ID
  modelCode     String?  @map("model_code") /// 模型标识
  success       Boolean  /// 是否成功
  errorMessage  String?  @map("error_message") @db.Text /// 错误信息
  costMs        Int      @map("cost_ms") /// 渲染耗时(毫秒)
  clientIp      String?  @map("client_ip") /// 客户端IP
  uid           String?  /// 调用用户唯一标识
  createdAt     DateTime @default(now())

  template PromptTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([templateId])
  @@index([templateCode])
  @@index([createdAt])
  @@map("prompt_invoke_logs")
}

/// 插件表 - 存储自定义函数插件
model Plugin {
  id          String   @id @default(uuid())
  name        String   @unique /// 插件名称
  version     String   /// 插件版本
  description String   @db.Text /// 插件描述
  author      String?  /// 作者
  status      Boolean  @default(true) /// 状态
  path        String   /// 插件路径
  config      String?  @db.Text /// 插件配置(JSON)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@index([status])
  @@map("plugins")
}
